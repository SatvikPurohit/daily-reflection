{
  "compilerOptions": {
    "target": "ES2020",
    "module": "CommonJS",
    "lib": ["ES2020"],
    "outDir": "dist",
    "rootDir": "src",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "baseUrl": ".",
    "paths": {
      "@repo/shared-types": ["../../libs/shared/types/src/index.ts"],
      "@repo/domain-reflection": ["../../libs/domain/reflection/src/index.ts"],
      "@repo/domain-analytics": ["../../libs/domain/analytics/src/analyticsService.ts"]
    }
  },
  "include": ["src/**/*.ts"],
  "exclude": ["node_modules", "dist"]
}
