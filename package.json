{
  "name": "daily-reflection",
  "version": "1.0.0",
  "description": "Daily Reflection App - Enterprise Grade pnpm Monorepo with NX & Module Federation",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@9.1.1",
  "repository": {
    "type": "git",
    "url": "https://github.com/SatvikPurohit/daily-reflection.git"
  },
  "author": "Satvik Purohit",
  "license": "MIT",
  "scripts": {
    "setup": "pnpm install && pnpm run db:setup",
    "predev": "pnpm run type-check",
    "dev": "pnpm run -r --parallel dev",
    "dev:shell": "pnpm -F shell dev",
    "dev:api": "pnpm -F api dev",
    "dev:observe": "pnpm -F observe-mfe dev",
    "dev:all": "pnpm run -r --parallel dev",
    "prebuild": "pnpm run type-check",
    "build": "pnpm run -r build",
    "build:shell": "pnpm -F shell build",
    "build:mfes": "pnpm run -r --filter './apps/*mfe' build",
    "build:api": "pnpm -F api build",
    "start": "pnpm -F shell start",
    "start:api": "pnpm -F api start",
    "preview": "pnpm run -r --parallel preview",
    "lint": "pnpm run -r lint",
    "format": "pnpm run -r format",
    "type-check": "pnpm run -r type-check",
    "test": "pnpm run -r test",
    "test:watch": "pnpm run -r test:watch",
    "test:coverage": "pnpm run -r test:coverage",
    "db:setup": "pnpm -F api run db:setup",
    "db:migrate": "pnpm -F api run db:migrate",
    "db:seed": "pnpm -F api run db:seed",
    "db:drop": "pnpm -F api run db:drop",
    "docker:up": "docker-compose up -d",
    "docker:down": "docker-compose down",
    "docker:logs": "docker-compose logs -f",
    "docker:clean": "docker-compose down -v",
    "clean": "pnpm run -r clean && pnpm store prune",
    "nx:graph": "nx graph",
    "nx:affected:build": "nx affected:build",
    "nx:affected:test": "nx affected:test"
  },
  "devDependencies": {
    "@nx/cli": "^19.0.0",
    "@nx/next": "^19.0.0",
    "@nx/node": "^19.0.0",
    "@nx/react": "^19.0.0",
    "@nx/jest": "^19.0.0",
    "@nx/linter": "^19.0.0",
    "@nx/workspace": "^19.0.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "autoprefixer": "^10.4.19",
    "eslint": "^8.57.0",
    "eslint-config-next": "^14.2.35",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "nx": "^19.0.0",
    "postcss": "^8.4.38",
    "prettier": "^3.2.5",
    "tailwindcss": "^3.4.3",
    "tsx": "^4.10.0",
    "typescript": "^5.4.5"
  },
  "pnpm": {
    "overrides": {
      "react": "^18.2.0",
      "react-dom": "^18.2.0"
    }
  }
}
