{
  "compilerOptions": {
    "target": "ES2020",
    "useDefineForClassFields": true,
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "skipLibCheck": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "strict": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "jsx": "react-jsx",
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "forceConsistentCasingInFileNames": true,
    "baseUrl": ".",
    "paths": {
      "@repo/shared-ui": ["libs/shared/ui/src/index.ts"],
      "@repo/shared-ui/*": ["libs/shared/ui/src/*"],
      "@repo/shared-store": ["libs/shared/store/src/index.ts"],
      "@repo/shared-store/*": ["libs/shared/store/src/*"],
      "@repo/shared-api-client": ["libs/shared/api-client/src/index.ts"],
      "@repo/shared-api-client/*": ["libs/shared/api-client/src/*"],
      "@repo/shared-types": ["libs/shared/types/src/index.ts"],
      "@repo/shared-types/*": ["libs/shared/types/src/*"],
      "@repo/shared-utils": ["libs/shared/utils/src/index.ts"],
      "@repo/shared-utils/*": ["libs/shared/utils/src/*"],
      "@repo/shared-workers": ["libs/shared/workers/src/index.ts"],
      "@repo/shared-workers/*": ["libs/shared/workers/src/*"],
      "@repo/domain-reflection": ["libs/domain/reflection/src/index.ts"],
      "@repo/domain-reflection/*": ["libs/domain/reflection/src/*"],
      "@repo/domain-user": ["libs/domain/user/src/index.ts"],
      "@repo/domain-user/*": ["libs/domain/user/src/*"],
      "@repo/domain-analytics": ["libs/domain/analytics/src/index.ts"],
      "@repo/domain-analytics/*": ["libs/domain/analytics/src/*"],
      "@repo/testing": ["libs/testing/src/index.ts"],
      "@repo/testing/*": ["libs/testing/src/*"]
    }
  },
  "include": ["**/*.ts", "**/*.tsx"],
  "exclude": ["**/node_modules", "**/dist", "**/.next"]
}
